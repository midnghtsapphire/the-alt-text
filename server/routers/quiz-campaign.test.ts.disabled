/**
 * Quiz-to-Campaign API Tests
 * 
 * Tests for the Universal API Stack Quiz-to-Campaign module integration
 */

import { describe, it, expect, beforeAll, vi } from 'vitest';
import { getDb } from '../db';
import { quizResponses, quizResults, affiliateLinks } from '../../drizzle/schema';
import { eq } from 'drizzle-orm';

// Mock the LLM module
vi.mock('../_core/llm', () => ({
  invokeLLM: vi.fn().mockResolvedValue({
    choices: [{
      message: {
        content: JSON.stringify({
          summary: "Based on your responses, you show strong potential in manufacturing careers.",
          topMatches: [
            {
              title: "Tool and Die Maker",
              description: "Your technical skills and attention to detail make this an excellent match.",
              confidenceScore: 90,
              salaryRange: "$45,000 - $75,000",
              transferableSkills: ["Precision work", "Technical drawing", "Problem solving"],
              nextSteps: ["Complete apprenticeship", "Get certified", "Build portfolio"]
            },
            {
              title: "CNC Machinist",
              description: "Your interest in automation and precision aligns well with CNC work.",
              confidenceScore: 85,
              salaryRange: "$40,000 - $65,000",
              transferableSkills: ["Computer skills", "Precision", "Quality control"],
              nextSteps: ["Learn CAD/CAM", "Get CNC certification", "Practice on simulators"]
            },
            {
              title: "Manufacturing Engineer",
              description: "Your problem-solving skills would be valuable in process improvement.",
              confidenceScore: 80,
              salaryRange: "$55,000 - $85,000",
              transferableSkills: ["Analysis", "Process optimization", "Technical communication"],
              nextSteps: ["Get engineering degree", "Learn lean manufacturing", "Gain shop floor experience"]
            }
          ],
          strengths: ["Technical aptitude", "Attention to detail", "Problem-solving"],
          areasForImprovement: ["Formal training", "Industry certifications"],
          personalizedAdvice: "Consider starting with an apprenticeship program to gain hands-on experience while earning. Focus on getting certified in precision measurement and blueprint reading."
        })
      }
    }]
  })
}));

describe('Quiz-Campaign API', () => {
  let db: Awaited<ReturnType<typeof getDb>>;

  beforeAll(async () => {
    db = await getDb();
    if (!db) {
      throw new Error('Database connection failed');
    }
  });

  describe('submitAssessment', () => {
    it('should store quiz response in database', async () => {
      // This test verifies that the quiz response is stored correctly
      const testAnswers = [
        { questionId: 'q1', value: 'Beginner' },
        { questionId: 'q2', value: 'Manufacturing' },
        { questionId: 'q3', value: 'Yes' }
      ];

      // Note: In a real test, we would call the tRPC procedure
      // For now, we're testing the database schema is correct
      const responseId = `test_resp_${Date.now()}`;
      
      await db!.insert(quizResponses).values({
        id: responseId,
        quizId: 'career_assessment',
        answers: testAnswers,
        leadInfo: { email: 'test@example.com' },
        score: 85,
        startedAt: new Date(),
        completedAt: new Date(),
        createdAt: new Date()
      });

      // Verify the response was stored
      const [stored] = await db!
        .select()
        .from(quizResponses)
        .where(eq(quizResponses.id, responseId))
        .limit(1);

      expect(stored).toBeDefined();
      expect(stored.id).toBe(responseId);
      expect(stored.quizId).toBe('career_assessment');
      expect(stored.score).toBe(85);

      // Clean up
      await db!.delete(quizResponses).where(eq(quizResponses.id, responseId));
    });

    it('should store AI insights in quiz results', async () => {
      const responseId = `test_resp_${Date.now()}`;
      const resultId = `test_result_${Date.now()}`;

      const aiInsights = {
        summary: "Test summary",
        topMatches: [
          {
            title: "Test Career",
            description: "Test description",
            confidenceScore: 90,
            salaryRange: "$50,000 - $70,000",
            transferableSkills: ["skill1", "skill2"],
            nextSteps: ["step1", "step2"]
          }
        ],
        strengths: ["strength1"],
        areasForImprovement: ["area1"],
        personalizedAdvice: "Test advice"
      };

      await db!.insert(quizResults).values({
        id: resultId,
        responseId: responseId,
        quizId: 'career_assessment',
        score: 85,
        aiInsights: aiInsights,
        createdAt: new Date()
      });

      // Verify the result was stored
      const [stored] = await db!
        .select()
        .from(quizResults)
        .where(eq(quizResults.id, resultId))
        .limit(1);

      expect(stored).toBeDefined();
      expect(stored.id).toBe(resultId);
      expect(stored.responseId).toBe(responseId);
      expect(stored.aiInsights).toBeDefined();

      // Clean up
      await db!.delete(quizResults).where(eq(quizResults.id, resultId));
    });

    it('should generate and store affiliate links', async () => {
      const trackingCode = `test_${Date.now()}`;
      const linkId = `aff_${trackingCode}`;

      await db!.insert(affiliateLinks).values({
        id: linkId,
        productId: 'tool_die_training',
        affiliateUrl: `https://tool-die-hub.com/training?ref=${trackingCode}`,
        trackingCode,
        campaign: 'test_campaign',
        medium: 'quiz',
        source: 'assessment',
        clicks: 0,
        conversions: 0,
        revenue: '0.00',
        createdAt: new Date()
      });

      // Verify the link was stored
      const [stored] = await db!
        .select()
        .from(affiliateLinks)
        .where(eq(affiliateLinks.id, linkId))
        .limit(1);

      expect(stored).toBeDefined();
      expect(stored.id).toBe(linkId);
      expect(stored.productId).toBe('tool_die_training');
      expect(stored.trackingCode).toBe(trackingCode);
      expect(stored.clicks).toBe(0);
      expect(stored.conversions).toBe(0);

      // Clean up
      await db!.delete(affiliateLinks).where(eq(affiliateLinks.id, linkId));
    });
  });

  describe('trackClick', () => {
    it('should increment affiliate link click count', async () => {
      const trackingCode = `test_${Date.now()}`;
      const linkId = `aff_${trackingCode}`;

      // Create a test affiliate link
      await db!.insert(affiliateLinks).values({
        id: linkId,
        productId: 'tool_die_training',
        affiliateUrl: `https://tool-die-hub.com/training?ref=${trackingCode}`,
        trackingCode,
        campaign: 'test_campaign',
        medium: 'quiz',
        source: 'assessment',
        clicks: 0,
        conversions: 0,
        revenue: '0.00',
        createdAt: new Date()
      });

      // Simulate tracking a click
      const [link] = await db!
        .select()
        .from(affiliateLinks)
        .where(eq(affiliateLinks.id, linkId))
        .limit(1);

      expect(link.clicks).toBe(0);

      // Increment click count
      await db!
        .update(affiliateLinks)
        .set({ 
          clicks: (link.clicks || 0) + 1,
          updatedAt: new Date()
        })
        .where(eq(affiliateLinks.id, linkId));

      // Verify click was tracked
      const [updated] = await db!
        .select()
        .from(affiliateLinks)
        .where(eq(affiliateLinks.id, linkId))
        .limit(1);

      expect(updated.clicks).toBe(1);

      // Clean up
      await db!.delete(affiliateLinks).where(eq(affiliateLinks.id, linkId));
    });
  });

  describe('Database Schema Validation', () => {
    it('should have correct quiz configs table structure', async () => {
      // This test verifies the schema is correctly defined
      // by attempting to query the table
      const result = await db!.select().from(quizResponses).limit(1);
      expect(Array.isArray(result)).toBe(true);
    });

    it('should have correct quiz results table structure', async () => {
      const result = await db!.select().from(quizResults).limit(1);
      expect(Array.isArray(result)).toBe(true);
    });

    it('should have correct affiliate links table structure', async () => {
      const result = await db!.select().from(affiliateLinks).limit(1);
      expect(Array.isArray(result)).toBe(true);
    });
  });

  describe('AI Integration', () => {
    it('should handle AI analysis responses', async () => {
      // Import the mocked function
      const { invokeLLM } = await import('../_core/llm');
      
      // Call the mocked function
      const response = await invokeLLM({
        messages: [
          { role: 'system', content: 'Test' },
          { role: 'user', content: 'Test' }
        ]
      });

      expect(response).toBeDefined();
      expect(response.choices).toBeDefined();
      expect(response.choices[0].message.content).toBeDefined();

      // Parse the AI response
      const content = response.choices[0].message.content;
      const aiInsights = JSON.parse(content as string);

      expect(aiInsights.summary).toBeDefined();
      expect(aiInsights.topMatches).toBeDefined();
      expect(Array.isArray(aiInsights.topMatches)).toBe(true);
      expect(aiInsights.topMatches.length).toBeGreaterThan(0);
      expect(aiInsights.topMatches[0].title).toBeDefined();
      expect(aiInsights.topMatches[0].confidenceScore).toBeGreaterThan(0);
    });
  });

  describe('Affiliate Link Generation', () => {
    it('should generate valid UTM parameters', () => {
      const trackingCode = 'test123';
      const utmSource = 'quiz';
      const utmMedium = 'assessment';
      const utmCampaign = 'career';

      const affiliateUrl = `https://tool-die-hub.com/training?utm_source=${utmSource}&utm_medium=${utmMedium}&utm_campaign=${utmCampaign}&utm_content=result&utm_term=${trackingCode}&ref=assessment&aff=${trackingCode}`;

      expect(affiliateUrl).toContain('utm_source=quiz');
      expect(affiliateUrl).toContain('utm_medium=assessment');
      expect(affiliateUrl).toContain('utm_campaign=career');
      expect(affiliateUrl).toContain(`utm_term=${trackingCode}`);
      expect(affiliateUrl).toContain(`aff=${trackingCode}`);
    });

    it('should use default values when UTM parameters are not provided', () => {
      const trackingCode = 'test123';
      const utmSource = 'quiz'; // default
      const utmMedium = 'assessment'; // default
      const utmCampaign = 'career'; // default

      const affiliateUrl = `https://tool-die-hub.com/training?utm_source=${utmSource}&utm_medium=${utmMedium}&utm_campaign=${utmCampaign}&utm_content=result&utm_term=${trackingCode}&ref=assessment&aff=${trackingCode}`;

      expect(affiliateUrl).toBeDefined();
      expect(affiliateUrl.length).toBeGreaterThan(0);
    });
  });
});
